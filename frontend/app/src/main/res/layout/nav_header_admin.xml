<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="220dp"
    android:background="@drawable/bg_admin_header"
    android:padding="24dp">

    <View
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:layout_marginTop="-40dp"
        android:layout_marginEnd="-60dp"
        android:background="@drawable/bg_white_circle_alpha" />

    <View
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_marginStart="-30dp"
        android:layout_marginTop="20dp"
        android:alpha="0.5"
        android:background="@drawable/bg_white_circle_alpha" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="vertical">

        <com.google.android.material.imageview.ShapeableImageView
            android:id="@+id/ivAdminProfile"
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:padding="2dp"
            android:src="@android:drawable/ic_menu_myplaces"
            android:background="@color/white"
            app:strokeColor="@color/admin_accent"
            app:strokeWidth="2dp"
            app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="System Administrator"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="admin.portal@attendify.edu"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="#20FFFFFF" />

    </LinearLayout>

</RelativeLayout>
