<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.AttendifyMobile" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Core branding colors -->
        <item name="colorPrimary">@color/admin_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/admin_primary_light</item>
        <item name="colorOnPrimaryContainer">@color/admin_primary</item>

        <!-- Secondary action colors -->
        <item name="colorSecondary">@color/admin_accent</item>
        <item name="colorOnSecondary">@color/white</item>

        <!-- Global UI Surface -->
        <item name="android:windowBackground">@color/admin_bg</item>
        <item name="android:statusBarColor">@color/admin_primary</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>

        <item name="toolbarStyle">@style/Widget.Attendify.Toolbar</item>
    </style>

    <style name="Widget.Attendify.Toolbar" parent="Widget.Material3.Toolbar">
        <item name="titleTextAppearance">@style/TextAppearance.Attendify.Toolbar.Title</item>
        <item name="background">@android:color/transparent</item>
        <item name="navigationIconTint">@color/white</item>
        <item name="titleTextColor">@color/white</item>
    </style>

    <style name="TextAppearance.Attendify.Toolbar.Title" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textSize">18sp</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <!-- Sidebar & Navigation Styles -->
    <style name="SidebarItemStyle">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">horizontal</item>
        <item name="android:padding">14dp</item>
        <item name="android:background">?attr/selectableItemBackground</item>
        <item name="android:gravity">center_vertical</item>
    </style>

    <style name="SidebarIconStyle">
        <item name="android:layout_width">22dp</item>
        <item name="android:layout_height">22dp</item>
        <item name="android:tint">@color/admin_text_secondary</item>
    </style>

    <style name="SidebarTextStyle">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:layout_marginStart">16dp</item>
        <item name="android:textColor">@color/admin_text_primary</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
