<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Dark Mode Theme: Professional Slate & Azure -->
    <style name="Theme.AttendifyMobile" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">#D6EAF8</item> <!-- Lighter Azure for Dark Mode -->
        <item name="colorOnPrimary">#1A252F</item>
        <item name="colorPrimaryContainer">#2C3E50</item>
        <item name="colorOnPrimaryContainer">#D6EAF8</item>

        <!-- Secondary brand color -->
        <item name="colorSecondary">#27AE60</item>
        <item name="colorOnSecondary">#FFFFFF</item>

        <!-- Surface and Background for Dark Mode -->
        <item name="android:windowBackground">#121212</item>
        <item name="android:statusBarColor">#121212</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>
</resources>
